# PhotoMagic Studio 环境变量配置示例
# 复制此文件为 .env.local（开发环境）或 .env.production（生产环境）

# ====================
# 应用基础配置
# ====================
VITE_APP_TITLE=PhotoMagic Studio
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=智能图片处理平台

# ====================
# API 配置
# ====================
# 开发环境 API 地址
VITE_API_BASE_URL=http://localhost:3001
VITE_API_TIMEOUT=30000

# ====================
# 功能开关
# ====================
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_SENTRY=false
VITE_ENABLE_DEBUG=false
VITE_ENABLE_PWA=true

# ====================
# 第三方服务（需要申请）
# ====================
# Sentry 错误监控
VITE_SENTRY_DSN=

# Google Analytics
VITE_GOOGLE_ANALYTICS_ID=

# 火山引擎（VolcEngine）API
VITE_VOLCENGINE_ACCESS_KEY=
VITE_VOLCENGINE_SECRET_KEY=

# 腾讯云 COS
VITE_TENCENT_COS_SECRET_ID=
VITE_TENCENT_COS_SECRET_KEY=
VITE_TENCENT_COS_REGION=
VITE_TENCENT_COS_BUCKET=

# ====================
# 开发调试
# ====================
# 设置为 true 时显示调试信息
VITE_DEBUG_MODE=false
# 模拟 API 响应（开发用）
VITE_MOCK_API=false
# Cloudflare Pages 环境变量
# 这些变量会在构建时注入

# 基础配置
VITE_APP_TITLE=PhotoMagic Studio
VITE_APP_VERSION=1.0.0

# API 配置
VITE_API_BASE_URL=http://101.32.246.47:3002
VITE_API_TIMEOUT=180000

# 功能开关
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_SENTRY=false

# 第三方服务
# VITE_SENTRY_DSN=your-sentry-dsn
# VITE_GOOGLE_ANALYTICS_ID=UA-XXXXX-Y
# VITE_STRIPE_PUBLIC_KEY=pk_test_xxxx
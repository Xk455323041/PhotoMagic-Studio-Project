# 服务配置
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# CORS配置
CORS_ORIGIN=http://localhost:3000

# Remove.bg 配置
REMOVE_BG_API_KEY=your_remove_bg_api_key
REMOVE_BG_ENDPOINT=https://api.remove.bg/v1.0

# VeLMagicX (火山引擎) 配置
VELMAGICX_ACCESS_KEY_ID=your_access_key_id
VELMAGICX_SECRET_ACCESS_KEY=your_secret_access_key
VELMAGICX_SERVICE_ID=your_service_id
VELMAGICX_REGION=cn-north-1
VELMAGICX_ENDPOINT=

# 文件存储配置
STORAGE_TYPE=local # local | s3
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760 # 10MB
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,image/gif

# Redis 配置
REDIS_URL=redis://localhost:6379

# JWT 配置
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=24h

# 速率限制
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000 # 15分钟

# 日志配置
LOG_LEVEL=info
LOG_FILE=./logs/app.log
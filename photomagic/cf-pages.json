{
  "build": {
    "command": "cd photomagic/frontend && npm install && npm run build",
    "output_dir": "photomagic/frontend/dist"
  },
  "environment_variables": {
    "NODE_VERSION": "18",
    "NODE_ENV": "production"
  },
  "routes": [
    {
      "pattern": "/*",
      "file": "photomagic/frontend/dist/index.html",
      "status": 200
    }
  ]
}